{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(login|register|dashboard|forum|data_lahan|edit_profil|moderasi_forum|peta_panen)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/api/auth.php?action=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}