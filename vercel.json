{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/index.html", "dest": "/index.html" },
    
    { "src": "/login", "dest": "/api/login.php" },
    { "src": "/login.php", "dest": "/api/login.php" },
    { "src": "/register", "dest": "/api/register.php" },
    { "src": "/register.php", "dest": "/api/register.php" },
    
    { "src": "/dashboard_admin", "dest": "/api/dashboard_admin.php" },
    { "src": "/dashboard_admin.php", "dest": "/api/dashboard_admin.php" },
    { "src": "/dashboard_user", "dest": "/api/dashboard_user.php" },
    { "src": "/dashboard_user.php", "dest": "/api/dashboard_user.php" },
    { "src": "/dashboard_user_supplier", "dest": "/api/dashboard_user_supplier.php" },
    { "src": "/dashboard_user_supplier.php", "dest": "/api/dashboard_user_supplier.php" },
    
    { "src": "/verifikasi_panen", "dest": "/api/verifikasi_panen.php" },
    { "src": "/verifikasi_panen.php", "dest": "/api/verifikasi_panen.php" },
    { "src": "/cetak_surat_jalan", "dest": "/api/cetak_surat_jalan.php" },
    { "src": "/cetak_surat_jalan.php", "dest": "/api/cetak_surat_jalan.php" },
    { "src": "/input_panen", "dest": "/api/input_panen.php" },
    { "src": "/input_panen.php", "dest": "/api/input_panen.php" },
    
    { "src": "/data_lahan", "dest": "/api/data_lahan.php" },
    { "src": "/data_lahan.php", "dest": "/api/data_lahan.php" },
    { "src": "/data_referensi", "dest": "/api/data_referensi.php" },
    { "src": "/data_referensi.php", "dest": "/api/data_referensi.php" },
    
    { "src": "/kelola_pengguna", "dest": "/api/kelola_pengguna.php" },
    { "src": "/kelola_pengguna.php", "dest": "/api/kelola_pengguna.php" },
    { "src": "/edit_profil", "dest": "/api/edit_profil.php" },
    { "src": "/edit_profil.php", "dest": "/api/edit_profil.php" },
    
    { "src": "/auth", "dest": "/api/auth.php" },
    { "src": "/auth.php", "dest": "/api/auth.php" },
    { "src": "/config", "dest": "/api/config.php" },
    { "src": "/config.php", "dest": "/api/config.php" },

    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    }
  ]
}
