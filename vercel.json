{
  "functions": {
    "api*/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/register", "dest": "/api/register.php" },
    { "src": "/login", "dest": "/api/login" },
    { "src": "/dashboard", "dest": "/api/dashboard.php" },
    { "src": "/auth/(.*)", "dest": "/api/auth.php?action=$1" },
    { "src": "/logout", "dest": "/api/auth.php?action=logout" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}