{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.2"
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/index.html", "dest": "/index.html" },
    
    { "src": "/auth/login", "dest": "/api/auth.php?action=login" },
    { "src": "/auth/register", "dest": "/api/auth.php?action=register" },
    { "src": "/auth/logout", "dest": "/api/auth.php?action=logout" },
    
    { "src": "/login", "dest": "/api/login.php" },
    { "src": "/login.php", "dest": "/api/login.php" },
    { "src": "/register", "dest": "/api/register.php" },
    { "src": "/register.php", "dest": "/api/register.php" },
    
    /* 🚀 TAMBAHAN ROUTING BARU UNTUK MULTI-DASHBOARD PANENUSA */
    { "src": "/dashboard_admin", "dest": "/api/dashboard_admin.php" },
    { "src": "/dashboard_admin.php", "dest": "/api/dashboard_admin.php" },
    { "src": "/dashboard_user", "dest": "/api/dashboard_user.php" },
    { "src": "/dashboard_user.php", "dest": "/api/dashboard_user.php" },
    
    { "src": "/dashboard", "dest": "/api/dashboard.php" },
    { "src": "/dashboard.php", "dest": "/api/dashboard.php" },
    { "src": "/data_lahan", "dest": "/api/data_lahan.php" },
    { "src": "/data_lahan.php", "dest": "/api/data_lahan.php" },
    { "src": "/forum", "dest": "/api/forum.php" },
    { "src": "/forum.php", "dest": "/api/forum.php" },
    { "src": "/kelola_pengguna", "dest": "/api/kelola_pengguna.php" },
    { "src": "/kelola_pengguna.php", "dest": "/api/kelola_pengguna.php" },
    { "src": "/edit_profil", "dest": "/api/edit_profil.php" },
    { "src": "/edit_profil.php", "dest": "/api/edit_profil.php" },
    { "src": "/peta_panen", "dest": "/api/peta_panen.php" },
    { "src": "/peta_panen.php", "dest": "/api/peta_panen.php" },

    {
      "src": "/(.*)",
      "dest": "/$1",
      "check": true
    }
  ]
}
