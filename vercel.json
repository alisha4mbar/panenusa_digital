{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/auth/(.*)",
      "dest": "/api/auth.php?action=$1"
    },
    {
      "src": "/login",
      "dest": "/api/login.php"
    },
    {
      "src": "/register",
      "dest": "/api/register.php"
    },
    {
      "src": "/dashboard",
      "dest": "/api/dashboard.php"
    },
    {
      "src": "/logout",
      "dest": "/api/logout.php"
    },
    {
      "src": "/forum",
      "dest": "/api/forum.php"
    },
    {
      "src": "/data-lahan",
      "dest": "/api/data_lahan.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}