{
  "functions": {
    "API/*.php": {
      "runtime": "vercel-php@0.7.5"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "dest": "/index.html"
    },
    {
      "src": "/API/login.php",
      "dest": "/API/login.php"
    },
    {
      "src": "/API/register.php",
      "dest": "/API/register.php"
    },
    {
      "src": "/API/dashboard.php",
      "dest": "/API/dashboard.php"
    },
    {
      "src": "/API/logout.php",
      "dest": "/API/logout.php"
    },
    {
      "src": "/API/data_lahan.php",
      "dest": "/API/data_lahan.php"
    },
    {
      "src": "/API/(.*)\\.php",
      "dest": "/API/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/API/$1.php"
    }
  ]
}